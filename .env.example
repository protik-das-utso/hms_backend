# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# ── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://dms_user:dms_pass@localhost:5432/dms_db?schema=public

# ── JWT ────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-in-production-access-secret-very-long-string
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret-very-long-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── App ────────────────────────────────────────────────
APP_NAME=Diagnostic Management System
PUBLIC_BASE_URL=http://localhost:3000

# ── SMS ────────────────────────────────────────────────
# Provider options:
#   log           - dev only, logs to console (default)
#   ssl_wireless  - SSL Wireless smsplus  (https://sslwireless.com)
#   onnorokom     - OnnoRokom SMS         (https://onnorokomsms.com)
#   greenweb      - Greenweb gsms         (https://greenweb.com.bd)
#   mim           - Mim SMS               (https://mimsms.com)
#   twilio        - Twilio                (international, https://twilio.com)
#   http          - custom HTTP gateway   (set SMS_HTTP_URL + template below)
SMS_PROVIDER=log
SMS_SENDER_ID=DMS

# For SSL Wireless / OnnoRokom / Greenweb / Mim — just provide your API key:
SMS_HTTP_TOKEN=

# For Twilio:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# For a fully custom HTTP gateway (provider=http):
# SMS_HTTP_URL=https://your-gateway.example.com/send
# SMS_HTTP_BODY_TEMPLATE={"to":"{to}","message":"{body}","sender":"{sender}"}
# SMS_HTTP_AUTH_HEADER=Authorization
# SMS_HTTP_AUTH_SCHEME=Bearer

# ── File Storage ──────────────────────────────────────
STORAGE_DIR=./storage
