// ─── Support tickets enums ────────────────────────────────────────

enum SupportTicketStatus {
  RECEIVED      // newly opened, waiting platform triage
  PENDING       // waiting on tenant's reply / more info
  IN_PROGRESS   // platform is actively working on it
  RESOLVED      // platform marked done; tenant can reopen by replying
  CLOSED        // closed for good (auto after X days resolved, or manual)
}

enum SupportTicketSeverity {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportTicketCategory {
  BUG
  FEATURE_REQUEST
  QUESTION
  BILLING
  ACCOUNT
  OTHER
}

enum SupportMessageSide {
  TENANT     // posted by a clinic user
  PLATFORM   // posted by a platform admin
}

