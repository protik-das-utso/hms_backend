// ─────────────────────────────────────────────────────────────────
// Diagnostic Management System — Prisma Schema
// PostgreSQL 16 · MVP Phase 1 + Subscription
// ─────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

